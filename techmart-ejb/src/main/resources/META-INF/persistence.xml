<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="techmartPU" transaction-type="JTA">
        <jta-data-source>jdbc/TechMartDataSource</jta-data-source>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>

            <property name="eclipselink.logging.parameters" value="true"/>
            <property name="eclipselink.cache.size.Product" value="5000"/>

            <property name="eclipselink.logging.level" value="WARNING"/>
            <property name="eclipselink.target-database" value="MySQL"/>

            <property name="eclipselink.connection-pool.default.initial" value="200"/>
            <property name="eclipselink.connection-pool.default.max" value="1000"/>
            <property name="eclipselink.cache.shared.default" value="true"/>


        </properties>
    </persistence-unit>

</persistence>
